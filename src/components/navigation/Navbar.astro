---
import { site } from "../../data/site";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;
const currentPath = Astro.url.pathname;
const siteData = site[lang];

// La sección activa se resuelve en el cliente (Intersection Observer).
// Aquí solo determinamos si estamos en la home para el estado inicial.
const homePath = lang === "es" ? "/es/" : "/";
const isHome = currentPath === homePath || currentPath === homePath.slice(0, -1);

function getAlternateLangPath(): string {
  if (lang === "es") {
    if (currentPath === "/es" || currentPath === "/es/") return "/";
    return currentPath.replace(/^\/es/, "");
  } else {
    if (currentPath === "/") return "/es/";
    return `/es${currentPath}`;
  }
}
---

<header id="site-navbar" class="glass-nav" role="banner">
  <div class="container nav-inner">
    <!-- Logo / Wordmark -->
    <a
      href={lang === "es" ? "/es/" : "/"}
      class="wordmark"
      aria-label="Alpes Tech — Home"
      id="navbar-logo"
    >
      <img src="/favicon.svg" alt="" class="wordmark-icon" width="24" height="24" aria-hidden="true" />
      <span class="wordmark-text">
        <span class="wordmark-brand">Alpes</span><span class="wordmark-accent"
          >Tech</span
        >
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Main navigation">
      {
        siteData.nav.map((link) => (
          <a
            href={link.href}
            id={link.id}
            data-nav-section={link.section}
            class:list={[
              "nav-link",
              { "nav-link--active": isHome && link.section === "inicio" },
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={getAlternateLangPath()}
        class="lang-switch-btn"
        aria-label={lang === "en" ? "Cambiar a Español" : "Switch to English"}
      >
        {lang === "en" ? "ES" : "EN"}
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="mobile-menu"
    aria-hidden="true"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="mobile-menu-inner">
      {
        siteData.nav.map((link) => (
          <a
            href={link.href}
            data-nav-section={link.section}
            class:list={[
              "mobile-nav-link",
              { "mobile-nav-link--active": isHome && link.section === "inicio" },
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={getAlternateLangPath()}
        class="mobile-nav-link mobile-nav-link--lang"
      >
        🌐 {lang === "en" ? "Español (ES)" : "English (EN)"}
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Navbar base ── */
  #site-navbar {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 50;
    transition: box-shadow 250ms ease;
  }

  #site-navbar.scrolled {
    box-shadow: 0 4px 24px hsl(0 0% 0% / 0.4);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  /* ── Wordmark ── */
  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .wordmark-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .wordmark-text {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .wordmark-brand {
    color: hsl(var(--foreground));
  }

  .wordmark-accent {
    color: hsl(var(--primary));
  }

  /* ── Desktop nav ── */
  .nav-desktop {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    position: relative;
    padding-block: 0.25rem;
    transition: color 250ms ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    inset-inline: 0;
    height: 2px;
    background: hsl(var(--primary));
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform 250ms ease;
    transform-origin: left;
  }

  .nav-link:hover {
    color: hsl(var(--foreground));
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    transform: scaleX(1);
  }

  .nav-link--active {
    color: hsl(var(--primary));
    font-weight: 600;
  }

  .lang-switch-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border: 1px solid hsl(var(--border));
    border-radius: var(--radius);
    transition:
      border-color 250ms ease,
      color 250ms ease,
      background-color 250ms ease;
    cursor: pointer;
  }

  .lang-switch-btn:hover {
    border-color: hsl(var(--primary) / 0.5);
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.05);
  }

  /* ── Mobile menu button ── */
  .mobile-menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 6px;
    transition: background 200ms ease;
  }

  .mobile-menu-btn:hover {
    background: hsl(var(--secondary));
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: hsl(var(--foreground));
    border-radius: 1px;
    transition:
      transform 300ms ease,
      opacity 300ms ease;
    transform-origin: center;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu panel ── */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    transition: max-height 350ms ease;
    border-top: 1px solid hsl(var(--border) / 0);
    transition:
      max-height 350ms ease,
      border-color 350ms ease;
  }

  .mobile-menu[aria-hidden="false"] {
    max-height: 400px;
    border-top-color: hsl(var(--border) / 0.5);
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid hsl(var(--border) / 0.3);
    transition: color 200ms ease;
  }

  .mobile-nav-link:last-child {
    border-bottom: none;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link--active {
    color: hsl(var(--primary));
  }

  .mobile-nav-link--lang {
    color: hsl(var(--primary));
    font-weight: 600;
  }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLElement;

  btn?.addEventListener("click", () => {
    const isOpen = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!isOpen));
    menu.setAttribute("aria-hidden", String(isOpen));
  });

  // Close mobile menu on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      btn?.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
    });
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    const navbar = document.getElementById("site-navbar");
    if (!navbar?.contains(e.target as Node)) {
      btn?.setAttribute("aria-expanded", "false");
      menu?.setAttribute("aria-hidden", "true");
    }
  });

  // Scrolled class for shadow
  const navbar = document.getElementById("site-navbar");
  window.addEventListener(
    "scroll",
    () => {
      navbar?.classList.toggle("scrolled", window.scrollY > 10);
    },
    { passive: true },
  );

  // ── Active section highlight (Intersection Observer) ──
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-section]"),
  );

  if (navLinks.length) {
    const sectionIds = [
      ...new Set(navLinks.map((l) => l.dataset.navSection)),
    ].filter(Boolean) as string[];

    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    function setActive(id: string) {
      navLinks.forEach((link) => {
        const isMatch = link.dataset.navSection === id;
        link.classList.toggle("nav-link--active", isMatch && link.classList.contains("nav-link"));
        link.classList.toggle(
          "mobile-nav-link--active",
          isMatch && link.classList.contains("mobile-nav-link"),
        );
      });
    }

    if (sections.length) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]?.target?.id) {
            setActive(visible[0].target.id);
          }
        },
        {
          rootMargin: "-45% 0px -45% 0px",
          threshold: [0, 0.25, 0.5, 0.75, 1],
        },
      );

      sections.forEach((section) => observer.observe(section));
    }
  }
</script>
