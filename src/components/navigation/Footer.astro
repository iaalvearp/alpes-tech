---
import { site } from "../../data/site";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;
const siteData = site[lang];

const navigationHeader = lang === "en" ? "Navigation" : "Navegación";
const connectHeader = lang === "en" ? "Connect" : "Contacto";
const allRightsReserved =
  lang === "en" ? "All rights reserved." : "Todos los derechos reservados.";
const ecosystemMessage =
  lang === "en"
    ? "Part of the Alpes Tech ecosystem"
    : "Parte del ecosistema Alpes Tech";
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a
        href={lang === "es" ? "/es/" : "/"}
        class="footer-wordmark"
        aria-label="Alpes Tech"
      >
        <span aria-hidden="true">⛰</span>
        <span>
          <span style="color: hsl(var(--foreground))">Alpes</span><span
            class="footer-accent">Tech</span
          >
        </span>
      </a>
      <p class="footer-tagline">{siteData.tagline}</p>
    </div>

    <!-- Nav links -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-nav-group">
        <h3 class="footer-nav-title">{navigationHeader}</h3>
        <ul>
          {
            siteData.nav.map((link) => (
              <li>
                <a href={link.href} class="footer-link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-nav-group">
        <h3 class="footer-nav-title">{connectHeader}</h3>
        <ul>
          <li>
            <a
              href={site.github}
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer">GitHub ↗</a
            >
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`} class="footer-link">
              {site.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Alpes Tech. {allRightsReserved}
      </p>
      <p class="footer-ecosystem">
        {ecosystemMessage}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: auto;
    border-top: 1px solid hsl(var(--border) / 0.5);
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      hsl(var(--primary) / 0.5) 50%,
      transparent 100%
    );
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 3rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .footer-wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-accent {
    color: hsl(var(--primary));
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.5;
    max-width: 320px;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
  }

  .footer-nav-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-nav-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground) / 0.7);
  }

  .footer-link {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-link:hover {
    color: hsl(var(--foreground));
  }

  .footer-bottom {
    border-top: 1px solid hsl(var(--border) / 0.3);
    padding-block: 1.25rem;
  }

  .footer-bottom .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy,
  .footer-ecosystem {
    font-size: 0.8rem;
    color: hsl(var(--muted-foreground) / 0.7);
  }
</style>
