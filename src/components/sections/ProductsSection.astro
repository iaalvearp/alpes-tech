---
import { productsEn, productsEs } from "../../data/products";
import { site } from "../../data/site";
import SectionHeading from "../ui/SectionHeading.astro";
import ProductCard from "../cards/ProductCard.astro";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;
const products = lang === "en" ? productsEn : productsEs;

// Translations
const eyebrow = lang === "en" ? "Our Products" : "Productos";
const title =
  lang === "en"
    ? "Software Built for Developers"
    : "Software Creado para Desarrolladores";
const subtitle =
  lang === "en"
    ? "Tools designed to make you more productive, wherever you are."
    : "Herramientas diseñadas para aumentar tu productividad, estés donde estés.";

const moreTitle = lang === "en" ? "More coming soon" : "Más en camino";
const moreText =
  lang === "en"
    ? "We're building the next wave of developer tools."
    : "Estamos construyendo la próxima generación de herramientas para programadores.";
const stayTuned = lang === "en" ? "Stay tuned ↗" : "Mantente al tanto ↗";
---

<section id="products" class="section" aria-labelledby="products-heading">
  <div class="container">
    <div class="section-header">
      <SectionHeading eyebrow={eyebrow} title={title} subtitle={subtitle} />
    </div>

    <div class="products-grid">
      {products.map((product) => <ProductCard product={product} lang={lang} />)}
    </div>

    {
      products.length === 1 && (
        <div class="products-more animate-fade-up-delay-2">
          <div class="products-more-card glass">
            <div class="products-more-icon" aria-hidden="true">
              🚀
            </div>
            <h3 class="products-more-title">{moreTitle}</h3>
            <p class="products-more-text">
              {moreText}
              <br />
              <a
                href={`mailto:${site.contact.email}`}
                class="products-more-link"
              >
                {stayTuned}
              </a>
            </p>
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .products-more {
    margin-top: 1.25rem;
  }

  .products-more-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2rem;
    border-radius: var(--radius);
    text-align: center;
    border: 1px dashed hsl(var(--border));
    background: hsl(var(--card) / 0.3);
  }

  .products-more-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .products-more-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: hsl(var(--foreground));
  }

  .products-more-text {
    font-size: 0.9rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
  }

  .products-more-link {
    color: hsl(var(--primary));
    text-decoration: none;
    font-weight: 500;
    transition: opacity 200ms ease;
  }

  .products-more-link:hover {
    opacity: 0.8;
  }
</style>
