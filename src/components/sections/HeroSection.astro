---
import CTAButton from "../ui/CTAButton.astro";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const eyebrowText =
  lang === "en"
    ? "Software · Tools · AI · Cloud"
    : "Software · Herramientas · IA · Nube";
const exploreText = lang === "en" ? "Explore Products" : "Explorar Productos";
const productsLink = lang === "es" ? "/es/products" : "/products";
---

<section id="inicio" class="hero-section" aria-label="Hero">
  <!-- Video background -->
  <div class="hero-video-bg" aria-hidden="true">
    <video
      class="hero-video"
      src="/alpes_hero.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      Your browser does not support the video tag.
    </video>
    <div class="hero-video-overlay"></div>
  </div>

  <!-- Foreground pattern -->
  <div class="triangle-pattern hero-pattern" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container hero-container">
    <div class="hero-content">
      <!-- Eyebrow -->
      <div class="eyebrow-badge animate-fade-up">
        <span class="eyebrow-dot animate-pulse-glow" aria-hidden="true"></span>
        <span>{eyebrowText}</span>
      </div>

      <!-- Heading -->
      <h1 class="hero-title animate-fade-up-delay-1">
        <span class="hero-title-brand">Alpes</span><span
          class="hero-title-accent">Tech</span
        >
      </h1>

      <!-- Tagline -->
      <p class="hero-tagline animate-fade-up-delay-2">
        Building software products for developers.
      </p>

      <!-- CTA -->
      <div class="hero-ctas animate-fade-up-delay-3">
        <CTAButton href={productsLink} variant="primary" id="hero-cta-products">
          {exploreText}
        </CTAButton>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="hero-fade-bottom" aria-hidden="true"></div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    padding-top: 8rem;
    padding-bottom: 5rem;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-section {
      padding-top: 9rem;
      padding-bottom: 6rem;
    }
  }

  /* ── Video background ── */
  .hero-video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      hsl(var(--background) / 0.7) 0%,
      hsl(var(--background) / 0.5) 50%,
      hsl(var(--background) / 0.85) 100%
    );
  }

  /* ── Pattern overlay ── */
  .hero-pattern {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.15;
    pointer-events: none;
  }

  /* ── Container ── */
  .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
  }

  /* ── Content ── */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 680px;
    text-align: center;
  }

  .hero-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .hero-title-brand {
    color: hsl(var(--foreground));
  }

  .hero-title-accent {
    color: hsl(var(--primary));
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: hsl(var(--muted-foreground));
    line-height: 1.65;
    max-width: 520px;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  /* Bottom fade */
  .hero-fade-bottom {
    position: absolute;
    bottom: 0;
    inset-inline: 0;
    z-index: 1;
    height: 5rem;
    background: linear-gradient(to bottom, transparent, hsl(var(--background)));
    pointer-events: none;
  }
</style>
