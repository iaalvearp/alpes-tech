---
import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";

interface Props {
  lang?: "en" | "es";
  showCta?: boolean;
}

const { lang = "en", showCta = false } = Astro.props;

// Translations
const eyebrow = lang === "en" ? "About" : "Nosotros";
const title = "Alpes Tech";
const subtitle =
  lang === "en"
    ? "We're a technology company devoted to research, innovation and the delivery of technological, IT, digital and software services. We care about simplicity, performance and great developer experience."
    : "Somos una empresa de tecnología dedicada a la investigación, la innovación y la prestación de servicios tecnológicos, informáticos, digitales y de software. Nos importa la simplicidad, el rendimiento y una gran experiencia de desarrollo.";

// Research & innovation highlight (objeto social)
const focusBadge =
  lang === "en" ? "Research & Innovation" : "Investigación e Innovación";
const focusTitle =
  lang === "en"
    ? "Research, innovation and technology services"
    : "Investigación, innovación y servicios tecnológicos";
const focusText =
  lang === "en"
    ? "We invest in research and innovation to deliver technological, IT, digital and software services — together with all related and complementary activities that drive our clients forward."
    : "Invertimos en investigación e innovación para la prestación de servicios tecnológicos, informáticos, digitales y de software, junto con todas las actividades conexas o complementarias que impulsan a nuestros clientes.";

const ctaLabel = lang === "en" ? "Learn more" : "Conocer más";
const ctaHref = lang === "es" ? "/es/#nosotros" : "/#nosotros";
---

<section
  id="nosotros"
  class="section about-section"
  aria-labelledby="about-heading"
>
  <!-- Subtle background pattern -->
  <div class="about-pattern triangle-pattern" aria-hidden="true"></div>

  <div class="container about-container">
    <!-- Intro -->
    <div class="about-intro">
      <SectionHeading
        eyebrow={eyebrow}
        title="Alpes Tech"
        subtitle={subtitle}
        align="center"
      />
    </div>

    <!-- Research & innovation highlight -->
    <div class="about-focus glass">
      <div class="about-focus-badge eyebrow-badge">
        <span class="eyebrow-dot animate-pulse-glow" aria-hidden="true"></span>
        <span>{focusBadge}</span>
      </div>
      <h3 class="about-focus-title">{focusTitle}</h3>
      <p class="about-focus-text">{focusText}</p>
    </div>

    {
      showCta && (
        <div class="about-cta">
          <CTAButton href={ctaHref} variant="secondary" id="about-learn-more">
            {ctaLabel}
          </CTAButton>
        </div>
      )
    }
  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: hidden;
  }

  .about-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    pointer-events: none;
  }

  .about-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .about-intro {
    max-width: 680px;
    margin-inline: auto;
  }

  /* Stats */
  .about-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    padding: 2rem;
    background: hsl(var(--card) / 0.5);
    border: 1px solid hsl(var(--border) / 0.5);
    border-radius: var(--radius);
    backdrop-filter: blur(12px);
  }

  .about-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }

  .stat-value {
    font-family: "Space Grotesk", sans-serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: hsl(var(--muted-foreground));
    font-family: "JetBrains Mono", monospace;
  }

  .about-stat-divider {
    width: 1px;
    height: 2.5rem;
    background: hsl(var(--border));
    display: none;
  }

  @media (min-width: 640px) {
    .about-stat-divider {
      display: block;
    }
  }

  /* Research & innovation highlight */
  .about-focus {
    padding: 2.25rem;
    border-radius: calc(var(--radius) * 1.5);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    align-items: center;
  }

  .about-focus-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: hsl(var(--foreground));
    max-width: 620px;
  }

  .about-focus-text {
    font-size: 0.95rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.7;
    max-width: 680px;
  }

  .about-cta {
    display: flex;
    justify-content: center;
  }
</style>
