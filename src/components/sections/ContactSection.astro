---
import { site } from "../../data/site";
import SectionHeading from "../ui/SectionHeading.astro";

interface Props {
  showHeading?: boolean;
  lang?: "en" | "es";
}

const { showHeading = true, lang = "en" } = Astro.props;

// Translations
const eyebrow = lang === "en" ? "Contact" : "Contacto";
const title = lang === "en" ? "Get in Touch" : "Ponte en Contacto";
const subtitle =
  lang === "en"
    ? "Have a question, idea, or just want to say hello? We'd love to hear from you."
    : "¿Tienes alguna pregunta, idea o simplemente quieres saludar? Nos encantaría saber de ti.";

const emailLabel = lang === "en" ? "Email" : "Correo electrónico";
const socialLabel = lang === "en" ? "Social media" : "Redes sociales";
const socialText =
  lang === "en"
    ? "Social profiles coming soon."
    : "Perfiles de redes sociales próximamente.";
---

<section
  id="contact"
  class="section contact-section"
  aria-labelledby="contact-heading"
>
  <!-- Glow background -->
  <div class="contact-glow" aria-hidden="true"></div>

  <div class="container contact-container">
    {
      showHeading && (
        <SectionHeading eyebrow={eyebrow} title={title} subtitle={subtitle} />
      )
    }

    <div class="contact-card glass">
      <!-- Email -->
      <div class="contact-item">
        <div class="contact-item-icon" aria-hidden="true">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <div class="contact-item-content">
          <span class="contact-item-label">{emailLabel}</span>
          <a
            href={`mailto:${site.contact.email}`}
            class="contact-item-value"
            id="contact-email-link"
          >
            {site.contact.email}
          </a>
        </div>
      </div>

      <div class="contact-divider"></div>

      <!-- GitHub -->
      <div class="contact-item">
        <div class="contact-item-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
        </div>
        <div class="contact-item-content">
          <span class="contact-item-label">GitHub</span>
          <a
            href={site.github}
            class="contact-item-value"
            target="_blank"
            rel="noopener noreferrer"
            id="contact-github-link"
          >
            github.com/iaalvearp ↗
          </a>
        </div>
      </div>

      <!-- Social placeholder -->
      <div class="contact-divider"></div>

      <div class="contact-social-placeholder">
        <span class="contact-social-label">{socialLabel}</span>
        <p class="contact-social-text">{socialText}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 300px;
    background: radial-gradient(
      ellipse 60% 80% at 50% 100%,
      hsl(var(--primary) / 0.12),
      transparent 70%
    );
    pointer-events: none;
  }

  .contact-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .contact-card {
    max-width: 540px;
    margin-inline: auto;
    width: 100%;
    padding: 2rem;
    border-radius: calc(var(--radius) * 1.5);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact-item-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius);
    background: hsl(var(--primary) / 0.1);
    border: 1px solid hsl(var(--primary) / 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: hsl(var(--primary));
    flex-shrink: 0;
  }

  .contact-item-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-item-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground) / 0.7);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-item-value {
    font-size: 0.95rem;
    color: hsl(var(--foreground));
    text-decoration: none;
    font-weight: 500;
    transition: color 200ms ease;
  }

  .contact-item-value:hover {
    color: hsl(var(--primary));
  }

  .contact-divider {
    width: 100%;
    height: 1px;
    background: hsl(var(--border) / 0.5);
  }

  .contact-social-placeholder {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-social-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground) / 0.7);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-social-text {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }
</style>
