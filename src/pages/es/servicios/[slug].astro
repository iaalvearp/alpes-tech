---
import DetailView from "../../../components/sections/DetailView.astro";
import { servicesEs, detailBase, overviewLabel } from "../../../data/details";

export function getStaticPaths() {
  return servicesEs.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<DetailView
  item={item}
  lang="es"
  overviewHref={detailBase("services", "es")}
  overviewLabel={overviewLabel("services", "es")}
/>
