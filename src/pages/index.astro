---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/navigation/Navbar.astro";
import Footer from "../components/navigation/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ServicesSection from "../components/sections/ServicesSection.astro";
import SolutionsSection from "../components/sections/SolutionsSection.astro";
import AboutSection from "../components/sections/AboutSection.astro";
import ProductsSection from "../components/sections/ProductsSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
---

<Layout lang="en">
  <Navbar lang="en" />

  <main id="main-content" tabindex="-1">
    <HeroSection lang="en" />

    <ServicesSection lang="en" />

    <div class="divider container-divider"></div>

    <SolutionsSection lang="en" />

    <div class="divider container-divider"></div>

    <AboutSection lang="en" showCta={true} />

    <div class="divider container-divider"></div>

    <ProductsSection lang="en" />

    <div class="divider container-divider"></div>

    <ContactSection lang="en" />
  </main>

  <Footer lang="en" />
</Layout>

<style>
  .container-divider {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 2rem;
  }
</style>
